# ─── EverCurrent Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Usage: cp .env.sample .env
#
# .env is gitignored and will NOT be committed.

# ─── LLM Provider API Keys ─────────────────────────────────────────────────
# The active provider is set in config/pipeline.yml (default: anthropic).
# Only the key for your chosen provider is required.

# Anthropic Claude - REQUIRED when provider=anthropic (default)
# Read implicitly by the Anthropic SDK constructor.
# Obtain from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI - required only when provider=openai
# Read implicitly by the OpenAI SDK constructor.
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini - required only when provider=google
# Read implicitly by the google-generativeai SDK.
# Obtain from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ─── Neo4j Knowledge Graph ───────────────────────────────────────────────
# Connection settings for the Neo4j graph database.
# Defaults match docker-compose.yml; override for remote instances.

# Bolt protocol URI for the Neo4j instance.
NEO4J_URI=bolt://localhost:7687

# Neo4j authentication credentials.
NEO4J_USER=neo4j
NEO4J_PASSWORD=evercurrent_dev
